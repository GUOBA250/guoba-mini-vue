{
  "name": "guoba-mini-vue",
  "version": "1.0.0",
  "description": "A mini Vue 3 implementation",
  "main": "lib/guoba-mini-vue.cjs.js",
  "module": "lib/guoba-mini-vue.esm.js",
  "types": "lib/index.d.ts",
  "files": [
